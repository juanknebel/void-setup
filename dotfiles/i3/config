set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term alacritty

font pango:Noto Sans 10
floating_modifier $mod
default_border pixel 2
default_floating_border pixel 2
hide_edge_borders none

# Colors (Breeze Dark — same palette as alacritty.toml)
# i3 client format: border background text indicator
client.focused          #3daee9 #232629 #eff0f1 #3daee9
client.focused_inactive #4d4d4d #232629 #7f8c8d #4d4d4d
client.unfocused        #4d4d4d #232629 #7f8c8d #4d4d4d
client.urgent           #ed1515 #ed1515 #eff0f1 #ed1515

# Floating popups for TUI launchers from the polybar.
# Match by WM_CLASS instance: launch via `alacritty --class <name>,Alacritty`
for_window [instance="nmtui"]     floating enable, resize set 800 600, move position center
for_window [instance="bluetui"]   floating enable, resize set 800 600, move position center
for_window [instance="pulsemixer"] floating enable, resize set 800 600, move position center

# exec_always runs on every reload (Mod+Shift+C). Kill old instances first so
# reloads don't stack duplicate daemons. The `sleep 0.3` avoids a cold-boot
# race where i3 fires these before the X session is fully initialized.
exec_always --no-startup-id sh -c 'pkill -x picom;    sleep 0.3; picom -b'
exec_always --no-startup-id sh -c 'pkill -x dunst;    sleep 0.3; dunst'
exec_always --no-startup-id sh -c 'pkill -x feh;      sleep 0.3; feh --bg-scale ~/Pictures/forest_2560x1600.jpg'
exec_always --no-startup-id sh -c 'pkill -x polybar;  sleep 0.3; ~/.config/polybar/launch.sh'
exec_always --no-startup-id mkdir -p ~/Pictures/Screenshots

# Auto-lock after 5 minutes of idle (xautolock + i3lock)
exec --no-startup-id xautolock -time 5 -locker ~/.local/bin/lock.sh

# PipeWire: SDDM autostart handles it via ~/.config/autostart, but an
# explicit exec ensures it starts when launching i3 from a TTY via startx.
exec --no-startup-id pipewire
exec --no-startup-id pipewire-pulse

bindsym $mod+Return exec $term
bindsym $mod+q kill
bindsym $mod+space exec rofi -show drun
bindsym $mod+Shift+e exec ~/.local/bin/powermenu.sh
bindsym $mod+Shift+f exec pcmanfm-qt

# Tablet — bezel rotation button emits XF86RotateWindows on the X61.
# Mod+Shift+R is the keyboard fallback for the same action.
bindsym XF86RotateWindows exec ~/.local/bin/rotate_screen_x11.sh
bindsym $mod+Shift+r exec ~/.local/bin/rotate_screen_x11.sh

# Window focus
bindsym $mod+$left  focus left
bindsym $mod+$down  focus down
bindsym $mod+$up    focus up
bindsym $mod+$right focus right

# Move windows
bindsym $mod+Shift+$left  move left
bindsym $mod+Shift+$down  move down
bindsym $mod+Shift+$up    move up
bindsym $mod+Shift+$right move right

# Workspaces 1-10 (0 = workspace 10)
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# Layout / container
bindsym $mod+b split h
bindsym $mod+v split v
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+space floating toggle
bindsym $mod+d focus mode_toggle

# i3 session (exit via powermenu on Shift+e)
bindsym $mod+Shift+c reload

# Resize mode
mode "resize" {
    bindsym $left  resize shrink width 10px
    bindsym $down  resize grow height 10px
    bindsym $up    resize shrink height 10px
    bindsym $right resize grow width 10px
    bindsym Left   resize shrink width 10px
    bindsym Down   resize grow height 10px
    bindsym Up     resize shrink height 10px
    bindsym Right  resize grow width 10px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# Screenshots — flameshot gui opens the annotation/capture UI
#   Print       = open flameshot GUI (select region or full screen, annotate)
#   Shift+Print = silent full-screen capture to ~/Pictures/Screenshots
bindsym Print       exec flameshot gui
bindsym Shift+Print exec flameshot screen -p ~/Pictures/Screenshots

# Multimedia keys (wpctl ships with wireplumber; brightnessctl in setup-base.sh)
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute        exec wpctl set-mute   @DEFAULT_AUDIO_SINK@   toggle
bindsym XF86AudioMicMute     exec wpctl set-mute   @DEFAULT_AUDIO_SOURCE@ toggle
bindsym XF86MonBrightnessUp   exec brightnessctl set 5%+
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-
