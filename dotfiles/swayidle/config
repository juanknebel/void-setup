# Swayidle policy — conservative defaults: lock after 10 minutes idle,
# suspend after 30 minutes. Also lock before going to sleep (so resume
# always lands on the swaylock prompt) and on any external lock signal
# (e.g. powermenu.sh, loginctl lock-session).
#
# The lock background colour matches the Plasma View Breeze Dark value
# (#232629) referenced in CLAUDE.md — keeps the lock screen visually
# consistent with the rest of the theming.

timeout 600 'swaylock -fF -c 232629'
timeout 1800 'loginctl suspend'
before-sleep 'swaylock -fF -c 232629'
lock 'swaylock -fF -c 232629'
