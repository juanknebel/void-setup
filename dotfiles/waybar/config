{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 0,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": [
        "temperature", "cpu", "memory",
        "custom/sep",
        "backlight", "pulseaudio",
        "custom/sep",
        "network", "bluetooth",
        "custom/sep",
        "battery",
        "tray"
    ],
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },
    "clock": {
        "timezone": "America/Argentina/Buenos_Aires",
        "format": "蟀 {:%H:%M}",
        "format-alt": "蟀笚 {:%a %d %b}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
        "interval": 5,
        "format": "蟀崨 {usage}%",
        "tooltip": false
    },
    "memory": {
        "interval": 5,
        "format": " {percentage}%",
        "tooltip-format": "{used:0.1f} GiB / {total:0.1f} GiB"
    },
    "temperature": {
        "interval": 5,
        "thermal-zone": 0,
        "critical-threshold": 80,
        "format": "蟀攺 {temperatureC}掳",
        "format-critical": "蟀竵 {temperatureC}掳"
    },
    "network": {
        "format-wifi": "蟀柀 {essid}",
        "format-ethernet": "蟀垁 {ifname}",
        "format-disconnected": "蟀柂",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr} ({signalStrength}%)",
        "on-click": "foot --app-id=foot-nmtui -e nmtui"
    },
    "bluetooth": {
        "format-on": "蟀偗",
        "format-connected": "蟀偙 {device_alias}",
        "format-disabled": "蟀偛",
        "format-off": "蟀偛",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click": "foot --app-id=foot-bluetui -e bluetui"
    },
    "backlight": {
        "format": "蟀儫 {percent}%",
        "scroll-step": 5
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "蟀潫",
        "format-icons": {
            "default": ["蟀暱", "蟀杸", "蟀暰"]
        },
        "on-click": "foot --app-id=foot-pulsemixer -e pulsemixer"
    },
    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon} {capacity}%",
        "format-charging": "蟀倓 {capacity}%",
        "format-plugged": "蟀殽 {capacity}%",
        "format-icons": ["蟀値", "蟀伜", "蟀伝", "蟀伡", "蟀伣", "蟀伨", "蟀伩", "蟀個", "蟀倎", "蟀倐", "蟀伖"]
    },
    "custom/sep": {
        "format": "",
        "tooltip": false
    },
    "tray": {
        "spacing": 8
    }
}
