{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 0,
    "margin-top": 10,
    "margin-left": 14,
    "margin-right": 14,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": [
        "temperature", "cpu", "memory",
        "custom/sep",
        "backlight", "pulseaudio",
        "custom/sep",
        "network", "bluetooth",
        "custom/sep",
        "battery",
        "tray"
