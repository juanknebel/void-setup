set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term alacritty

font pango:Noto Sans 10
floating_modifier $mod normal
default_border pixel 2
default_floating_border pixel 2
hide_edge_borders none

# Colors (Breeze Dark Theme Matching — palette consistent with alacritty.toml)
# Sway client format: border background text indicator child_border
client.focused          #3daee9 #232629 #eff0f1 #3daee9   #3daee9
client.focused_inactive #4d4d4d #232629 #7f8c8d #4d4d4d   #4d4d4d
client.unfocused        #4d4d4d #232629 #7f8c8d #4d4d4d   #4d4d4d
client.urgent           #ed1515 #ed1515 #eff0f1 #ed1515   #ed1515

# Floating popups for the network / bluetooth / audio TUIs launched from
# waybar. Matching by app_id (set via foot --app-id=...) so the rule only
# affects these specific terminal popups, not every foot window.
for_window [app_id="^foot-(nmtui|bluetui|pulsemixer)$"] floating enable, resize set 800 600, move position center

# exec_always runs on every reload (Mod+Shift+C). Without killing the
# previous instance first, each reload would stack a new waybar/mako/swaybg.
# The `sleep 0.3` avoids the cold-boot race from SDDM, where sway fires
# these exec_always commands before the Wayland socket is ready for clients;
# without the delay, helpers start, fail to connect, and die.
# Wrapped in `sh -c '...'` because `;` is a separator at the sway-config level.
exec_always sh -c 'pkill -x swaybg; sleep 0.3; swaybg -i ~/Pictures/forest_2560x1600.jpg -m fill'
exec_always sh -c 'pkill -x mako; sleep 0.3; mako'
exec_always sh -c 'pkill -x waybar; sleep 0.3; waybar'

# Screenshots: target dir for grim+satty captures (see Print bindings below).
exec_always mkdir -p ~/Pictures/Screenshots

# Audio stack: Sway does NOT honor ~/.config/autostart/*.desktop the way
# Plasma/GNOME do, so launch PipeWire + its Pulse compatibility layer
# explicitly. wireplumber gets auto-spawned by pipewire via the system-level
# 10-wireplumber.conf drop-in installed by setup-system.sh.
exec pipewire
exec pipewire-pulse

exec swayidle -w \
    timeout 300 'swaylock -c 232629 --ring-color 3daee9 --inside-color 31363b --text-color eff0f1' \
    timeout 600 'loginctl suspend' \
    before-sleep 'swaylock -c 232629 --ring-color 3daee9 --inside-color 31363b --text-color eff0f1'

bindsym $mod+Return exec $term
bindsym $mod+q kill
bindsym $mod+d exec fuzzel --background-color=232629ff --text-color=eff0f1ff --match-color=3daee9ff --selection-color=31363bff --selection-text-color=eff0f1ff --border-color=3daee9ff --border-width=2
bindsym $mod+Shift+e exec ~/.local/bin/powermenu.sh
bindsym $mod+Shift+f exec pcmanfm-qt

# Tablet Management Triggers
# OSK moved to Shift+t to free Shift+k (move window up).
# Rotation: bezel button emits XF86TaskPane (X220-specific keysym, not the
# natural XF86RotateWindows). Both triggers (button + keyboard) are kept.
bindsym XF86TaskPane exec ~/.local/bin/rotate_screen_twm.sh
bindsym $mod+Shift+r exec ~/.local/bin/rotate_screen_twm.sh
bindsym $mod+Shift+t exec killall wvkbd || wvkbd-mobintl --bg 232629 --fg eff0f1 --press 3daee9 &

# Window focus
bindsym $mod+$left  focus left
bindsym $mod+$down  focus down
bindsym $mod+$up    focus up
bindsym $mod+$right focus right

# Move windows (Shift + direction)
bindsym $mod+Shift+$left  move left
bindsym $mod+Shift+$down  move down
bindsym $mod+Shift+$up    move up
bindsym $mod+Shift+$right move right

# Workspaces 1-10 (0 = workspace 10)
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# Layout / container
bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

# Sway session (exit via powermenu on Shift+e)
bindsym $mod+Shift+c reload

# Resize mode (Shift+r is taken by screen rotation; use $mod+r instead)
mode "resize" {
    bindsym $left  resize shrink width 10px
    bindsym $down  resize grow height 10px
    bindsym $up    resize shrink height 10px
    bindsym $right resize grow width 10px
    bindsym Left   resize shrink width 10px
    bindsym Down   resize grow height 10px
    bindsym Up     resize shrink height 10px
    bindsym Right  resize grow width 10px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# Screenshots — grim (capture) + slurp (region select) + satty (annotate)
#   Print              = full screen → satty annotation editor
#   Shift+Print        = region      → satty annotation editor
#   Ctrl+Shift+Print   = region      → wl-copy (clipboard, no editor)
# satty's --output-filename makes the Save button use that path by default.
bindsym Print            exec grim - | satty -f - --output-filename ~/Pictures/Screenshots/screenshot-$(date +%Y%m%d-%H%M%S).png
bindsym Shift+Print      exec grim -g "$(slurp)" - | satty -f - --output-filename ~/Pictures/Screenshots/screenshot-$(date +%Y%m%d-%H%M%S).png
bindsym Ctrl+Shift+Print exec grim -g "$(slurp)" - | wl-copy

# Multimedia keys (wpctl ships with wireplumber; brightnessctl in setup-system.sh).
# --locked: keep working while swaylock is active.
bindsym --locked XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym --locked XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym --locked XF86AudioMute        exec wpctl set-mute   @DEFAULT_AUDIO_SINK@   toggle
bindsym --locked XF86AudioMicMute     exec wpctl set-mute   @DEFAULT_AUDIO_SOURCE@ toggle
bindsym --locked XF86MonBrightnessUp   exec brightnessctl set 5%+
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-

include /etc/sway/config.d/*
